DATABASE_URL="postgresql://postgres:postgres@localhost:5432/alexcraft2026?schema=public"

LINE_CHANNEL_ACCESS_TOKEN=""
LINE_CHANNEL_SECRET=""
LINE_LOGIN_CHANNEL_ID=""
LINE_LOGIN_CHANNEL_SECRET=""
LIFF_ID=""
# Rich Menu preset ใช้ลิงก์ https://liff.line.me/<LIFF_ID>?p=/liff/... — ตั้ง LIFF Endpoint URL ใน LINE Developers เป็น {APP_BASE_URL}/liff
ALLOW_DEMO_LIFF_PROFILE="false"

# โอกาสได้รางวัลเมื่อเปิดกล่อง (0-1) — default ในโค้ดคือ 0.3 ถ้าไม่ตั้งค่า
REWARD_DRAW_WIN_PROBABILITY="0.3"

# สัดส่วนโควต้ารางวัลตาม milestone (เทียบกับสต็อกรวมปัจจุบัน): "w1,w2" — เช่น 3แก้ว 60% / 6แก้ว 30% / ที่เหลือไป 10แก้ว + ทบยอดเหลือจาก milestone ก่อนหน้า
REWARD_DRAW_MILESTONE_SHARES="0.6,0.3"

APP_BASE_URL="http://localhost:3000"

# URL สำหรับปุ่ม Live preview บนหน้า /display/checkin (iframe ใต้ navbar) — ลำดับ: LIVE_PREVIEW_URL → ADMIN_LIVE_PREVIEW_URL → default ในโค้ด
NEXT_PUBLIC_LIVE_PREVIEW_URL=""
NEXT_PUBLIC_ADMIN_LIVE_PREVIEW_URL=""

# หน้าจอ TV แสดงผู้เช็คอินแบบ real-time (Socket.IO — รันแอปผ่าน server.mjs: npm run dev / npm start)
# โทเคนสำหรับเปิดหน้า /display/checkin?token=... เท่านั้น (สตริงยาวสุ่ม)
DISPLAY_TV_TOKEN=""
# เปิด POST /api/display/simulate-checkin ใน production/staging (จำลอง check-in บนจอ TV โดยไม่แตะ DB) — dev ใช้ได้โดยไม่ต้องตั้ง
DISPLAY_SIMULATE_CHECKIN=""
LINE_WEBHOOK_PATH="/api/webhook/line"
LT_SUBDOMAIN=""
ADMIN_PASSWORD="admin1234"
ADMIN_SESSION_SECRET="replace-with-random-secret"

PAYMENT_PER_PERSON_THB="799"
PAYMENT_QR_EXPIRY_MINUTES="30"
PROMPTPAY_ID="0812345678"

# หลัง self-checkout ใช้ลำดับ: COMPLETED → GUEST → CONFIRMED ถ้ามี id อย่างใดอย่างหนึ่ง
# ถ้าไม่ตั้งทั้งสาม ระบบจะถอด per-user rich menu ให้กลับไปใช้ default ของ OA
RICH_MENU_ID_GUEST=""
RICH_MENU_ID_PENDING=""
RICH_MENU_ID_WAITING_PAYMENT=""
RICH_MENU_ID_CONFIRMED=""
RICH_MENU_ID_CHECKED_IN=""
RICH_MENU_ID_COMPLETED=""
RICH_MENU_ID_CANCELLED=""
RICH_MENU_MAPS_URL=""

