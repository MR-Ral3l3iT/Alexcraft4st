{
  "name": "alexcraft2026",
  "version": "1.0.0",
  "description": "Event registration and check-in platform",
  "scripts": {
    "dev": "node server.mjs",
    "dev:next": "next dev",
    "tunnel": "ngrok http 3000",
    "tunnel:cf": "cloudflared tunnel --url http://localhost:3000",
    "tunnel:lt": "lt --port 3000",
    "dev:tunnel": "concurrently -k \"npm run dev\" \"npm run tunnel\"",
    "build": "next build",
    "start": "node server.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "line:richmenu:create": "node scripts/line/create-richmenu.mjs",
    "line:richmenu:create:pending": "node scripts/line/create-richmenu.mjs --preset pending",
    "line:richmenu:create:confirmed": "node scripts/line/create-richmenu.mjs --preset confirmed",
    "line:richmenu:create:checked-in": "node scripts/line/create-richmenu.mjs --preset checked_in",
    "line:richmenu:link": "node scripts/line/link-richmenu.mjs",
    "db:reset-user-flow": "node scripts/db/reset-user-flow.mjs"
  },
  "private": true,
  "dependencies": {
    "@line/bot-sdk": "^11.0.0",
    "@prisma/client": "^6.19.3",
    "lucide-react": "^1.7.0",
    "next": "^16.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.2",
    "localtunnel": "^2.0.2",
    "postcss": "^8.5.9",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vitest": "^1.6.0"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  }
}
