generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  pending
  waiting_payment_review
  confirmed
  cancelled
  checked_in
}

enum RewardType {
  general
  coupon
}

model Booking {
  id            String        @id @default(cuid())
  lineUserId    String        @unique
  lineDisplay   String?
  linePictureUrl String?
  fullName      String
  phone         String
  seats         Int           @default(1)
  note          String?
  slipUrl       String?
  paymentAmount Int?
  paymentRef    String?       @unique
  paymentQrPayload String?
  paymentQrImageUrl String?
  paymentRequestedAt DateTime?
  paymentExpiresAt DateTime?
  bookingCode   String?       @unique
  qrCodePayload String?
  status        BookingStatus @default(pending)
  checkedInAt   DateTime?
  drinkCount    Int           @default(0)
  drinkLastAt   DateTime?
  checkedOutAt  DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  statusLogs    BookingStatusLog[]
  checkinLogs   CheckinLog[]
  rewardDraws   RewardDraw[]

  @@index([status])
  @@index([phone])
  @@index([createdAt])
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String   @default("staff")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  checkinLogs CheckinLog[]
  statusLogs  BookingStatusLog[]
}

model CheckinLog {
  id          String   @id @default(cuid())
  bookingId   String
  adminUserId String?
  method      String   @default("qr")
  createdAt   DateTime @default(now())

  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  adminUser AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([bookingId, createdAt])
  @@index([adminUserId])
}

model BookingStatusLog {
  id          String        @id @default(cuid())
  bookingId   String
  adminUserId String?
  fromStatus  BookingStatus?
  toStatus    BookingStatus
  reason      String?
  createdAt   DateTime      @default(now())

  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  adminUser AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([bookingId, createdAt])
  @@index([toStatus])
}

model EventSettings {
  id               Int      @id @default(1)
  capacity         Int      @default(40)
  venueLat         Float?
  venueLng         Float?
  checkinRadiusM   Int      @default(100)
  checkinStartAt   DateTime?
  checkinEndAt     DateTime?
  drinkCooldownSec Int      @default(600)
  drinkMaxPerUser  Int      @default(10)
  paymentAmountThb Int      @default(799)
  paymentAccountNo String?
  paymentBankName  String?
  paymentAccountName String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Reward {
  id            String     @id @default(cuid())
  code          String     @unique
  name          String
  type          RewardType @default(general)
  quantity      Int        @default(0)
  imageUrl      String
  couponStartAt DateTime?
  couponEndAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  rewardDraws   RewardDraw[]

  @@index([type])
  @@index([createdAt])
}

// 1 ครั้งต่อ milestone (3/6/10 แก้ว) ต่อ 1 booking — ใช้เก็บผลสุ่ม + กันกดซ้ำ
model RewardDraw {
  id              String   @id @default(cuid())
  bookingId       String
  lineUserId      String
  milestoneLevel  Int
  won             Boolean
  rewardId        String?
  rewardName      String?
  loseReason      String?
  winProbability  Float
  createdAt       DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reward  Reward? @relation(fields: [rewardId], references: [id], onDelete: SetNull)

  @@unique([bookingId, milestoneLevel])
  @@index([lineUserId, milestoneLevel])
  @@index([createdAt])
}
