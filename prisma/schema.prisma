generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  pending
  waiting_payment_review
  confirmed
  cancelled
  checked_in
}

model Booking {
  id            String        @id @default(cuid())
  lineUserId    String        @unique
  lineDisplay   String?
  linePictureUrl String?
  fullName      String
  phone         String
  seats         Int           @default(1)
  note          String?
  slipUrl       String?
  paymentAmount Int?
  paymentRef    String?       @unique
  paymentQrPayload String?
  paymentQrImageUrl String?
  paymentRequestedAt DateTime?
  paymentExpiresAt DateTime?
  bookingCode   String?       @unique
  qrCodePayload String?
  status        BookingStatus @default(pending)
  checkedInAt   DateTime?
  drinkCount    Int           @default(0)
  drinkLastAt   DateTime?
  checkedOutAt  DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  statusLogs    BookingStatusLog[]
  checkinLogs   CheckinLog[]

  @@index([status])
  @@index([phone])
  @@index([createdAt])
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String   @default("staff")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  checkinLogs CheckinLog[]
  statusLogs  BookingStatusLog[]
}

model CheckinLog {
  id          String   @id @default(cuid())
  bookingId   String
  adminUserId String?
  method      String   @default("qr")
  createdAt   DateTime @default(now())

  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  adminUser AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([bookingId, createdAt])
  @@index([adminUserId])
}

model BookingStatusLog {
  id          String        @id @default(cuid())
  bookingId   String
  adminUserId String?
  fromStatus  BookingStatus?
  toStatus    BookingStatus
  reason      String?
  createdAt   DateTime      @default(now())

  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  adminUser AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([bookingId, createdAt])
  @@index([toStatus])
}

model EventSettings {
  id               Int      @id @default(1)
  capacity         Int      @default(40)
  venueLat         Float?
  venueLng         Float?
  checkinRadiusM   Int      @default(100)
  checkinStartAt   DateTime?
  checkinEndAt     DateTime?
  drinkCooldownSec Int      @default(600)
  drinkMaxPerUser  Int      @default(10)
  paymentAmountThb Int      @default(799)
  paymentAccountNo String?
  paymentBankName  String?
  paymentAccountName String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
